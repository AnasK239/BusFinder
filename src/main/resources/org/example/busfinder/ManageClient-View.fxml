<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="768.0" prefWidth="1200.0" stylesheets="@dashboard.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.busfinder.controllers.ClientManagementController">

    <VBox prefHeight="768.0" prefWidth="313.0" styleClass="sidebar">

        <HBox alignment="CENTER_LEFT" prefHeight="101.0" prefWidth="226.0" spacing="15.0" styleClass="sidebar-header">
            <padding>
                <Insets bottom="30.0" left="20.0" right="20.0" top="30.0" />
            </padding>
            <Label styleClass="logo-icon" text="🚌" />
            <VBox alignment="CENTER_LEFT">
                <Label styleClass="logo-title" text="TripManager" />
                <Label styleClass="logo-subtitle" text="Admin Panel" />
            </VBox>
        </HBox>

        <VBox prefHeight="590.0" prefWidth="274.0" spacing="5.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets left="15.0" right="15.0" />
            </padding>
            <Button maxWidth="Infinity" onAction="#handleDashboard" styleClass="nav-btn" text="⊞   Dashboard" />
            <Button maxWidth="Infinity" styleClass="nav-btn, nav-btn-active" text="👥   Clients" />
            <Button maxWidth="Infinity" styleClass="nav-btn" text="🚌   Trips" />
            <Button maxWidth="Infinity" styleClass="nav-btn" text="📅   Reservations" />
            <Button maxWidth="Infinity" styleClass="nav-btn" text="🔍   View Trips" />
            <Button maxWidth="Infinity" styleClass="nav-btn" text="💬   Feedback" />
        </VBox>

        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="user-profile">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <Label prefHeight="37.0" prefWidth="43.0" styleClass="user-avatar" text="AD" />
            <VBox alignment="CENTER_LEFT">
                <Label prefHeight="19.0" prefWidth="88.0" styleClass="user-name" text="Admin " />
                <Label prefHeight="16.0" prefWidth="98.0" styleClass="user-email" text="admin@trip.com" />
            </VBox>
         <Button mnemonicParsing="false" onAction="#handleLogout" prefHeight="25.0" prefWidth="57.0" styleClass="main-content" text="Logout">
            <cursor>
               <Cursor fx:constant="HAND" />
            </cursor>
         </Button>
        </HBox>
    </VBox>

    <VBox prefHeight="768.0" prefWidth="996.0" spacing="30.0" styleClass="main-content" HBox.hgrow="ALWAYS">
        <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
        </padding>

        <VBox spacing="5.0">
            <Label styleClass="page-title" text="Client Management" />
            <Label styleClass="page-subtitle" text="Add and manage your clients" />
        </VBox>

        <VBox spacing="20.0" styleClass="table-container">
            <padding>
                <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
            </padding>

            <Label styleClass="table-title" text="Add New Client" />

            <VBox spacing="15.0">
                <HBox spacing="20.0">
                    <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="form-label" text="First Name" />
                        <TextField fx:id="firstNameField" promptText="Enter first name" styleClass="custom-text-field" />
                    </VBox>
                    <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="form-label" text="Last Name" />
                        <TextField fx:id="lastNameField" promptText="Enter last name" styleClass="custom-text-field" />
                    </VBox>
                </HBox>

                <HBox spacing="20.0">
                    <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="form-label" text="Email" />
                        <TextField fx:id="emailField" promptText="Enter email address" styleClass="custom-text-field" />
                    </VBox>
                    <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="form-label" text="Phone Number" />
                        <TextField fx:id="phoneField" promptText="Enter phone number" styleClass="custom-text-field" />
                    </VBox>
                </HBox>
            </VBox>

            <HBox alignment="CENTER_RIGHT">
                <Button mnemonicParsing="false" onAction="#handleAddClient" styleClass="primary-btn" text="+ Add Client" />
            </HBox>
        </VBox>

        <VBox spacing="15.0" styleClass="table-container" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <Label styleClass="table-title" text="Clients List" />

            <TableView fx:id="clientsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="100.0" text="Client ID" />
                    <TableColumn fx:id="colName" prefWidth="200.0" text="Name" />
                    <TableColumn fx:id="colEmail" prefWidth="250.0" text="Email" />
                    <TableColumn fx:id="colPhone" prefWidth="150.0" text="Phone" />
                    <TableColumn fx:id="colLoyalty" prefWidth="120.0" text="Loyalty Points" />
                    <TableColumn fx:id="colActions" prefWidth="100.0" text="Actions" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>
    </VBox>
</HBox>
