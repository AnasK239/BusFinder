<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="768.0" prefWidth="1200.0" stylesheets="@dashboard.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.busfinder.controllers.AdminDashboardController">

    <VBox prefWidth="250.0" styleClass="sidebar">

        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="sidebar-header">
            <Label styleClass="logo-icon" text="🚌" />
            <VBox alignment="CENTER_LEFT">
                <Label styleClass="logo-title" text="TripManager" />
                <Label styleClass="logo-subtitle" text="Admin Panel" />
            </VBox>
            <padding>
                <Insets bottom="30.0" left="20.0" right="20.0" top="30.0" />
            </padding>
        </HBox>

        <VBox spacing="5.0" VBox.vgrow="ALWAYS">
            <Button maxWidth="Infinity" styleClass="nav-btn, nav-btn-active" text="⊞   Dashboard" />
            <Button maxWidth="Infinity" onAction="#handleAddClient" styleClass="nav-btn" text="👥   Clients" />
            <Button maxWidth="Infinity" styleClass="nav-btn" text="🚌   Trips" />
            <Button maxWidth="Infinity" styleClass="nav-btn" text="📅   Reservations" />
            <Button maxWidth="Infinity" styleClass="nav-btn" text="🔍   View Trips" />
            <Button maxWidth="Infinity" styleClass="nav-btn" text="💬   Feedback" />
            <padding>
                <Insets left="15.0" right="15.0" />
            </padding>
        </VBox>

        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="user-profile">
            <Label styleClass="user-avatar" text="AD" />
            <VBox alignment="CENTER_LEFT">
                <Label styleClass="user-name" text="Admin" />
                <Label styleClass="user-email" text="admin@trip.com" />
            </VBox>
         <Button mnemonicParsing="false" onAction="#handleLogout" styleClass="main-content" text="Logout">
            <cursor>
               <Cursor fx:constant="HAND" />
            </cursor>
         </Button>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
        </HBox>
    </VBox>

    <VBox spacing="30.0" styleClass="main-content" HBox.hgrow="ALWAYS">
        <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
        </padding>

        <VBox spacing="5.0">
            <Label styleClass="page-title" text="Dashboard" />
            <Label styleClass="page-subtitle" text="Welcome back! Here's your overview" />
        </VBox>

        <HBox spacing="20.0">
            <HBox styleClass="summary-card" HBox.hgrow="ALWAYS">
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="Total Clients" />
                    <Label fx:id="totalClientsLabel" styleClass="card-value" />
                </VBox>
                <Label styleClass="card-icon, icon-blue" text="👥" />
            </HBox>
            <HBox styleClass="summary-card" HBox.hgrow="ALWAYS">
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="Active Trips" />
                    <Label fx:id="activeTripsLabel" styleClass="card-value" />
                </VBox>
                <Label styleClass="card-icon, icon-green" text="🚌" />
            </HBox>
            <HBox styleClass="summary-card" HBox.hgrow="ALWAYS">
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="Reservations" />
                    <Label fx:id="reservationsLabel" styleClass="card-value" />
                </VBox>
                <Label styleClass="card-icon, icon-purple" text="📅" />
            </HBox>
            <HBox styleClass="summary-card" HBox.hgrow="ALWAYS">
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title" text="Revenue" />
               <Label fx:id="revenueLabel" styleClass="card-value" />
                </VBox>
                <Label styleClass="card-icon, icon-orange" text="📈" />
            </HBox>
        </HBox>

        <VBox spacing="15.0" styleClass="table-container" VBox.vgrow="ALWAYS">
            <Label styleClass="table-title" text="Recent Trips" />

            <TableView fx:id="tripsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="100.0" text="Trip ID" />
                    <TableColumn fx:id="colRoute" prefWidth="250.0" text="Route" />
                    <TableColumn fx:id="colTime" prefWidth="150.0" text="Time" />
                    <TableColumn fx:id="colStatus" prefWidth="150.0" text="Status" />
                    <TableColumn fx:id="colSeats" prefWidth="100.0" text="Seats" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
        </VBox>

    </VBox>
</HBox>
