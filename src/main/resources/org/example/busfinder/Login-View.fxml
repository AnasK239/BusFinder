<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="768.0" prefWidth="1200.0" spacing="20.0" styleClass="main-content" stylesheets="@dashboard.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.busfinder.controllers.LoginController">

    <VBox maxWidth="500.0" spacing="25.0" styleClass="table-container">
        <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
        </padding>

        <VBox alignment="CENTER" spacing="5.0">
            <Label styleClass="logo-icon" style="-fx-font-size: 48px;" text="🚌" />
            <Label styleClass="page-title" text="Bus Reservation System" />
            <Label styleClass="page-subtitle" text="Please log in to continue" />
        </VBox>

        <VBox spacing="15.0">
            <VBox spacing="6.0">
                <Label styleClass="form-label" text="Username" />
                <TextField fx:id="usernameField" promptText="Enter your username or email" styleClass="custom-text-field" />
            </VBox>

            <VBox spacing="6.0">
                <Label styleClass="form-label" text="Password" />
                <PasswordField fx:id="passwordField" promptText="Enter your password" styleClass="custom-text-field" />
            </VBox>

            <HBox alignment="CENTER_RIGHT">
                <Button mnemonicParsing="false" onAction="#handleForgotPassword" style="-fx-background-color: transparent; -fx-text-fill: #0984e3;" text="Forgot Password?">
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </Button>
            </HBox>
        </VBox>

        <VBox alignment="CENTER">
            <Label fx:id="errorLabel" textFill="#e74c3c" visible="false" />
        </VBox>

        <VBox alignment="CENTER" spacing="15.0">
            <Button fx:id="loginButton" defaultButton="true" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleLogin" prefHeight="40.0" styleClass="primary-btn" text="Login">
                <cursor>
                    <Cursor fx:constant="HAND" />
                </cursor>
            </Button>

            <Button fx:id="createAccountButton" mnemonicParsing="false" onAction="#handleCreateAccount" style="-fx-background-color: transparent; -fx-text-fill: #0984e3; -fx-font-weight: bold;" text="Don't have an account? Create one here">
                <cursor>
                    <Cursor fx:constant="HAND" />
                </cursor>
            </Button>
        </VBox>

    </VBox>
</VBox>