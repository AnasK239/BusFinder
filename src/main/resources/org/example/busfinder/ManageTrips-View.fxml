<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="768.0" prefWidth="1200.0" stylesheets="@dashboard.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.busfinder.controllers.TripManagementController">

    <VBox prefHeight="768.0" prefWidth="313.0" styleClass="sidebar" HBox.hgrow="NEVER">

        <HBox alignment="CENTER_LEFT" prefHeight="101.0" prefWidth="226.0" spacing="15.0" styleClass="sidebar-header">
            <padding>
                <Insets bottom="30.0" left="20.0" right="20.0" top="30.0" />
            </padding>
            <Label styleClass="logo-icon" text="🚌" />
            <VBox alignment="CENTER_LEFT">
                <Label styleClass="logo-title" text="TripManager" />
                <Label styleClass="logo-subtitle" text="Admin Panel" />
            </VBox>
        </HBox>

        <VBox prefHeight="590.0" prefWidth="274.0" spacing="5.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets left="15.0" right="15.0" />
            </padding>
            <Button maxWidth="Infinity" onAction="#handleDashboard" styleClass="nav-btn" text="⊞   Dashboard" />
            <Button maxWidth="Infinity" onAction="#handleClients" styleClass="nav-btn" text="👥   Clients" />
            <Button maxWidth="Infinity" styleClass="nav-btn, nav-btn-active" text="🚌   Trips" />
            <Button maxWidth="Infinity" styleClass="nav-btn" text="📅   Reservations" />
            <Button maxWidth="Infinity" styleClass="nav-btn" text="🔍   View Trips" />
            <Button maxWidth="Infinity" styleClass="nav-btn" text="💬   Feedback" />
        </VBox>

        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="user-profile">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <Label prefHeight="37.0" prefWidth="43.0" styleClass="user-avatar" text="AD" />
            <VBox alignment="CENTER_LEFT">
                <Label prefHeight="19.0" prefWidth="88.0" styleClass="user-name" text="Admin User" />
                <Label prefHeight="16.0" prefWidth="98.0" styleClass="user-email" text="admin@trip.com" />
            </VBox>
            <Button mnemonicParsing="false" onAction="#handleLogout" prefHeight="25.0" prefWidth="57.0" styleClass="main-content" text="Logout">
                <cursor>
                    <Cursor fx:constant="HAND" />
                </cursor>
            </Button>
        </HBox>
    </VBox>

    <VBox prefHeight="768.0" prefWidth="996.0" spacing="15.0" styleClass="main-content" HBox.hgrow="ALWAYS">
        <padding>
            <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
        </padding>

        <VBox spacing="5.0" VBox.vgrow="NEVER">
            <Label styleClass="page-title" text="Trip Management" />
            <Label styleClass="page-subtitle" text="Create and manage trips" />
        </VBox>
      <Label fx:id="statusLabel" styleClass="form-label" />

        <VBox spacing="10.0" styleClass="table-container" VBox.vgrow="NEVER">
            <padding>
                <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
            </padding>

            <HBox alignment="BOTTOM_LEFT" spacing="15.0">
                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="form-label" text="Date *" />
                    <DatePicker fx:id="tripDatePicker" maxWidth="Infinity" promptText="dd/mm/yyyy" styleClass="custom-text-field" />
                </VBox>
                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="form-label" text="Dep. Time *" />
                    <TextField fx:id="departureTimeField" promptText="HH:MM" styleClass="custom-text-field" />
                </VBox>
                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="form-label" text="Arr. Time *" />
                    <TextField fx:id="arrivalTimeField" promptText="HH:MM" styleClass="custom-text-field" />
                </VBox>
                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="form-label" text="Base Fare *" />
                    <TextField fx:id="baseFareField" promptText="Fare" styleClass="custom-text-field" />
                </VBox>
            </HBox>

            <HBox alignment="BOTTOM_LEFT" spacing="15.0">
                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="form-label" text="Driver *" />
                    <ComboBox fx:id="driverComboBox" maxWidth="Infinity" promptText="Select Driver" styleClass="custom-text-field" />
                </VBox>
                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="form-label" text="Bus *" />
                    <ComboBox fx:id="busComboBox" maxWidth="Infinity" promptText="Select Bus" styleClass="custom-text-field" />
                </VBox>
                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="form-label" text="Route *" />
                    <ComboBox fx:id="routeComboBox" maxWidth="Infinity" promptText="Select Route" styleClass="custom-text-field" />
                </VBox>
                <VBox alignment="BOTTOM_RIGHT" HBox.hgrow="NEVER">
                    <Button fx:id="createButton" mnemonicParsing="false" onAction="#handleCreateTrip" prefHeight="40.0" prefWidth="165.0" styleClass="primary-btn" text="+ Create Trip">
                        <cursor>
                            <Cursor fx:constant="HAND" />
                        </cursor>
                    </Button>
                </VBox>
            </HBox>
        </VBox>

        <VBox spacing="10.0" styleClass="table-container" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
            <Label styleClass="table-title" text="Trips List" />

            <TableView fx:id="tripsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colTripId" prefWidth="80.0" text="Trip ID" />
                    <TableColumn fx:id="colDate" prefWidth="100.0" text="Date" />
                    <TableColumn fx:id="colTime" prefWidth="120.0" text="Time" />
                    <TableColumn fx:id="colDriver" prefWidth="150.0" text="Driver" />
                    <TableColumn fx:id="colBus" prefWidth="46.0" text="Bus" />
                    <TableColumn fx:id="colRoute" prefWidth="182.0" text="Route" />
                    <TableColumn fx:id="colFare" prefWidth="80.0" text="Fare" />
                    <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>

    </VBox>
</HBox>
