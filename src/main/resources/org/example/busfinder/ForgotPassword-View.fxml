<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="768.0" prefWidth="1200.0" spacing="20.0" styleClass="main-content" stylesheets="@dashboard.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.busfinder.controllers.ForgotPasswordController">

    <VBox maxWidth="500.0" spacing="25.0" styleClass="table-container">
        <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
        </padding>

        <VBox alignment="CENTER" spacing="5.0">
            <Label style="-fx-font-size: 48px;" styleClass="logo-icon" text="🔒" />
            <Label styleClass="page-title" text="Reset Password" />
            <Label styleClass="page-subtitle" text="Enter your username to change your password" />
        </VBox>

        <VBox spacing="15.0">
            <VBox spacing="6.0">
                <Label styleClass="form-label" text="Account Username *" />
                <TextField fx:id="usernameField" promptText="Enter your username" styleClass="custom-text-field" />
            </VBox>

            <VBox spacing="6.0">
                <Label styleClass="form-label" text="New Password *" />
                <PasswordField fx:id="newPasswordField" promptText="Enter new password" styleClass="custom-text-field" />
            </VBox>

            <VBox spacing="6.0">
                <Label styleClass="form-label" text="Confirm New Password *" />
                <PasswordField fx:id="confirmPasswordField" promptText="Confirm new password" styleClass="custom-text-field" />
            </VBox>
        </VBox>

        <VBox alignment="CENTER">
            <Label fx:id="statusLabel" textFill="#e74c3c" visible="false" />
        </VBox>

        <VBox alignment="CENTER" spacing="15.0">
            <Button fx:id="updateButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleChangePassword" prefHeight="40.0" styleClass="primary-btn" text="Update Password">
                <cursor>
                    <Cursor fx:constant="HAND" />
                </cursor>
            </Button>

            <Button mnemonicParsing="false" onAction="#handleBackToLogin" style="-fx-background-color: transparent; -fx-text-fill: #0984e3; -fx-font-weight: bold;" text="Back to Login">
                <cursor>
                    <Cursor fx:constant="HAND" />
                </cursor>
            </Button>
        </VBox>

    </VBox>
</VBox>
